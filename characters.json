/* =========================
   Reset
========================= */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* =========================
   Page Setup
========================= */

html,
body {
    width: 100%;
    height: 100%;
    overflow: hidden;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #4d4d4d 0%, #292929 100%);
    color: white;
}

/* =========================
   Settings Layout
========================= */

.settings-container {
    width: 100vw;
    height: 100vh;
    padding: clamp(16px, 4vw, 40px);

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.settings-main {
    width: min(900px, 100%);

    background: rgba(255, 255, 255, 0.08);
    border: 2px solid rgba(255, 255, 255, 0.16);
    border-radius: 20px;

    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);

    overflow: hidden;
}

/* =========================
   Header
========================= */

.settings-header {
    width: min(900px, 100%);
    margin-bottom: 24px;

    display: flex;
    align-items: center;
    justify-content: center;

    position: relative;
}

.settings-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
}

.btn-back {
    position: absolute;
    left: 0;

    color: white;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;

    padding: 12px 18px;
    border: 2px solid rgba(255, 255, 255, 0.4);
    border-radius: 14px;

    background: rgba(255, 255, 255, 0.08);
    transition: 0.2s ease;
}

.btn-back:hover {
    background: rgba(255, 255, 255, 0.18);
    transform: translateY(-2px);
}

/* =========================
   Tab Navigation
========================= */

.tabs-navigation {
    display: flex;
    gap: 10px;

    padding: 18px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.12);
}

.tab-button {
    flex: 1;

    padding: 14px 18px;
    border: none;
    border-radius: 12px;

    color: white;
    background: rgba(255, 255, 255, 0.1);

    font-weight: 800;
    cursor: pointer;

    transition: 0.25s ease;
}

.tab-button:hover,
.tab-button.active {
    background: linear-gradient(135deg, #4facfe 0%, #764ba2 100%);
}

/* =========================
   Tab Content
========================= */

.tab-content {
    display: none;
    padding: 26px;
}

.tab-content.active {
    display: block;
}

.tab-content h2 {
    margin-bottom: 20px;
    font-size: 1.5rem;
}

/* =========================
   Settings Items
========================= */

.settings-section {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.setting-item {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 14px;

    padding: 16px;
}

.checkbox-label,
.toggle-setting {
    display: flex;
    align-items: center;
    gap: 14px;

    cursor: pointer;
}

.divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.16);
    margin: 6px 0;
}

.placeholder-text {
    color: #d0d0d0;
}

/* =========================
   Setting Text
========================= */

.label-text {
    flex: 1;
}

.label-text strong {
    font-size: 1rem;
}

.setting-description {
    margin-top: 4px;
    color: #d0d0d0;
    font-size: 0.9rem;
}

/* =========================
   Custom Checkboxes
========================= */

.setting-checkbox {
    display: none;
}

.checkbox-custom {
    width: 24px;
    height: 24px;
    flex-shrink: 0;

    border: 2px solid rgba(255, 255, 255, 0.55);
    border-radius: 6px;

    display: flex;
    align-items: center;
    justify-content: center;
}

.setting-checkbox:checked + .checkbox-custom {
    background: linear-gradient(135deg, #4facfe 0%, #764ba2 100%);
    border-color: transparent;
}

.setting-checkbox:checked + .checkbox-custom::after {
    content: "✓";
    color: white;
    font-weight: 900;
}

/* =========================
   Toggle Switches
========================= */

.toggle-setting {
    justify-content: space-between;
}

.switch {
    position: relative;
    width: 76px;
    height: 36px;
    flex-shrink: 0;
}

.switch input {
    display: none;
}

.slider {
    position: absolute;
    inset: 0;

    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);

    cursor: pointer;
    transition: 0.25s ease;
}

.slider::before {
    content: "OFF";

    position: absolute;
    width: 30px;
    height: 30px;

    left: 3px;
    top: 3px;

    border-radius: 50%;
    background: white;

    color: #777;
    font-size: 0.55rem;
    font-weight: 900;

    display: flex;
    align-items: center;
    justify-content: center;

    transition: 0.25s ease;
}

.switch input:checked + .slider {
    background: linear-gradient(135deg, #4facfe 0%, #764ba2 100%);
}

.switch input:checked + .slider::before {
    content: "ON";
    transform: translateX(40px);
    color: #4facfe;
}

/* =========================
   Footer
========================= */

.settings-footer {
    width: min(900px, 100%);
    margin-top: 18px;
}

.btn-save {
    width: 100%;

    padding: 16px 24px;
    border: none;
    border-radius: 12px;

    color: white;
    background: linear-gradient(135deg, #4facfe 0%, #764ba2 100%);

    font-size: 1rem;
    font-weight: 800;

    cursor: pointer;
    transition: 0.25s ease;
}

.btn-save:hover {
    transform: translateY(-2px);
}

/* =========================
   Responsive Design
========================= */

@media (max-width: 700px) {
    html,
    body {
        overflow: auto;
        height: auto;
    }

    .settings-container {
        min-height: 100vh;
        height: auto;
    }

    .settings-header {
        flex-direction: column;
        gap: 16px;
    }

    .btn-back {
        position: static;
    }

    .tabs-navigation {
        flex-direction: column;
    }
}