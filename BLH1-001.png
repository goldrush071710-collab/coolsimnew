<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Custom Cards Simulator - Multiplayer</title>

    <link rel="icon" type="image/png" href="../images/basic/logo-without-title.png">
    <link rel="stylesheet" href="../css/style.css">
    <link rel="stylesheet" href="../css/multiplayer.css">
</head>
<body>
    <main class="multiplayer-page">
        <section class="multiplayer-card">
            <h1>Multiplayer</h1>
            <p class="subtitle">Create a room or join a friend using a room code.</p>

            <div class="connection-box">
                <p id="connectionStatus">Connecting...</p>
            </div>

            <div class="room-actions">
                <button id="createRoomBtn" class="primary-btn">
                    Create Room
                </button>

                <div class="divider">
                    <span>or</span>
                </div>

                <div class="join-box">
                    <input 
                        id="roomCodeInput" 
                        type="text" 
                        placeholder="Enter room code"
                        maxlength="6"
                    >

                    <button id="joinRoomBtn" class="secondary-btn">
                        Join Room
                    </button>
                </div>
            </div>

            <div class="room-info">
                <p id="roomStatus">No room created yet.</p>
                <p id="roomCodeDisplay"></p>
            </div>

            <div id="deckPicker" class="deck-picker hidden">
                <label for="deckSelect">Choose Deck</label>
                <select id="deckSelect"></select>

                <button id="readyBtn" class="secondary-btn">
                    Ready
                </button>

                <div class="ready-status">
                    <span id="player1ReadyStatus">Player 1: Not ready</span>
                    <span id="player2ReadyStatus">Player 2: Not ready</span>
                </div>
            </div>

            <button id="startMatchBtn" class="primary-btn hidden">
                Start Match
            </button>

            <a href="../index.html" class="back-link">Back to Main Menu</a>
        </section>
    </main>

    <script src="../js/cards/cardDatabase.js?v=ry-ichigo-1"></script>
    <script src="../js/cards/decks.js?v=ry-ichigo-1"></script>
    <script src="../js/core/deckParser.js"></script>
    <script type="module" src="../js/pages/multiplayer.js"></script>
</body>
</html>
