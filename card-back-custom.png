<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VS Self - Custom Cards</title>

    <link rel="icon" type="image/png" href="../images/basic/logo-without-title.png">
    <link rel="stylesheet" href="../css/style.css">
    <link rel="stylesheet" href="../css/self.css?v=bleach-effects-1">
</head>
<body>
    <a href="../index.html?view=game" class="btn-back">Back to Lobby</a>

    <main class="self-page">

        <div id="onlineMatchInfo" class="online-match-info hidden"></div>

        <div class="game-layout">
            <section class="game-board">

                <svg id="attackArrowOverlay" class="attack-arrow-overlay"></svg>

                <div class="hand opponent-hand" id="player2Hand"></div>
        
                <section class="play-area opponent-area">
                    <div class="character-area">
                        <div class="character-label">Character Area</div>
                        <div class="character-slot" data-player="player2" data-slot="0"></div>
                        <div class="character-slot" data-player="player2" data-slot="1"></div>
                        <div class="character-slot" data-player="player2" data-slot="2"></div>
                        <div class="character-slot" data-player="player2" data-slot="3"></div>
                        <div class="character-slot" data-player="player2" data-slot="4"></div>
                    </div>
        
                    <div class="life-area" id="lifeArea">
                        <span class="life-toggle-text" id="lifeToggleText">View Life Cards</span>
                    
                        <div class="life-card"></div>
                        <div class="life-card"></div>
                        <div class="life-card"></div>
                        <div class="life-card"></div>
                        <div class="life-card"></div>
                    </div>
        
                    <div class="area leader-area" id="player2LeaderArea"></div>
                    <div class="area stage-area" id="player2StageArea"></div>
                    <div class="area deck-area" id="player2DeckArea"></div>
        
                    <div class="area don-deck-area" id="player2DonDeckArea"></div>
                    <div class="area don-area" id="player2DonArea"></div>
                    <div class="area trash-area" id="player2TrashArea"></div>
                </section>

                <div class="battle-controls" id="battleControls"></div>
        
                <section class="play-area player-area">
                    <div class="character-area">
                        <div class="character-label">Character Area</div>
                        <div class="character-slot" data-player="player1" data-slot="0"></div>
                        <div class="character-slot" data-player="player1" data-slot="1"></div>
                        <div class="character-slot" data-player="player1" data-slot="2"></div>
                        <div class="character-slot" data-player="player1" data-slot="3"></div>
                        <div class="character-slot" data-player="player1" data-slot="4"></div>
                    </div>
        
                    <div class="life-area" id="opponentLifeArea">
                        <span class="life-toggle-text" id="opponentLifeToggleText">View Life Cards</span>
                    
                        <div class="life-card"></div>
                        <div class="life-card"></div>
                        <div class="life-card"></div>
                        <div class="life-card"></div>
                        <div class="life-card"></div>
                    </div>
        
                    <div class="area leader-area" id="player1LeaderArea"></div>
                    <div class="area stage-area" id="player1StageArea"></div>
                    <div class="area deck-area" id="player1DeckArea"></div>
        
                    <div class="area don-deck-area" id="player1DonDeckArea"></div>
                    <div class="area don-area" id="player1DonArea"></div>
                    <div class="area trash-area" id="player1TrashArea"></div>
                </section>

                <div class="hand player-hand" id="player1Hand"></div>
        
            </section>

            <aside class="card-preview-panel">
                <div class="card-preview">
                    <div class="preview-placeholder" id="previewPlaceholder">
                        Hover a card to preview it
                    </div>

                    <img id="previewImage" class="preview-image" src="" alt="Card Preview">
                </div>

                <div class="phase-controls">
                    <button id="phaseButton" class="phase-button">Starting...</button>
                    <button id="nextPhaseButton" class="phase-button secondary-phase-button" type="button" disabled>Next Phase</button>
                </div>

                <div class="game-log">
                    <h3>Game Log</h3>
                    <div id="gameLogMessages" class="game-log-messages"></div>
                </div>
            </aside>
            
        </div>
    </main>

    <script src="../js/core/phases.js?v=creation-13"></script>
    <script src="../js/core/effectBlocks.js?v=blocks-1"></script>
    <script src="../js/core/effectBlockParser.js?v=blocks-1"></script>
    <script src="../js/core/effectBlockValidator.js?v=blocks-1"></script>
    <script src="../js/core/customEffectV2.js?v=custom-v2-10"></script>

    <script src="../js/cards/cardDatabase.js?v=creation-14"></script>
    <script src="../js/cards/decks.js?v=creation-13"></script>
    <script src="../js/core/deckParser.js"></script>

    <script src="../js/core/effects.js?v=creation-14"></script>
    <script src="../js/core/gameInteractions.js?v=bleach-effects-1"></script>
    <script src="../js/core/customEffectV2Engine.js?v=custom-v2-10"></script>

    <script src="../js/pages/self.js?v=bleach-effects-1"></script>
</body>
</html>
